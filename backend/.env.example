# EasyShare backend environment variables (copy to .env)
# All variables are prefixed with EASYSHARE_

# A long, random secret used to sign JWT tokens. REQUIRED in production.
EASYSHARE_SECRET_KEY=change-me-to-a-long-random-value

EASYSHARE_ENVIRONMENT=development
EASYSHARE_DEBUG=true

# Database (SQLite by default; use postgresql+psycopg://... in production)
EASYSHARE_DATABASE_URL=sqlite:///./easyshare.db

# Where uploaded files are stored
EASYSHARE_STORAGE_DIR=./storage

# Access token lifetime (minutes)
EASYSHARE_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins
EASYSHARE_CORS_ORIGINS=http://localhost:5173

# Comma-separated reverse-proxy IPs whose X-Forwarded-For uvicorn will trust.
# Read by the Docker entrypoint, so it must be a real environment variable (set
# it in docker-compose, not just this file). Use your proxy's IP in production;
# use "*" only when the backend port is not publicly reachable.
EASYSHARE_FORWARDED_ALLOW_IPS=127.0.0.1
