# EasyShare backend environment variables (copy to .env)
# All variables are prefixed with EASYSHARE_

# A long, random secret used to sign JWT tokens. REQUIRED in production.
EASYSHARE_SECRET_KEY=change-me-to-a-long-random-value

EASYSHARE_ENVIRONMENT=development

# Database (SQLite by default; use postgresql+psycopg://... in production)
EASYSHARE_DATABASE_URL=sqlite:///./easyshare.db

# Where uploaded files are stored
EASYSHARE_STORAGE_DIR=./storage

# Store files under opaque random names on disk (true, default) or readable
# {package_id}/{file_id}_{filename} paths (false). The original filename is
# always kept in the database regardless.
# EASYSHARE_OBFUSCATE_STORAGE_NAMES=true

# Access token lifetime (minutes)
EASYSHARE_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins
EASYSHARE_CORS_ORIGINS=http://localhost:5173

# Optional GlitchTip (Sentry-compatible) crash reporting. When set, this CSP
# security-report endpoint is added to the Content-Security-Policy as a
# report-uri and its origin is allowed in connect-src so the SPA's crash SDK is
# not blocked. Pair with the frontend VITE_GLITCHTIP_DSN build-time variable.
# EASYSHARE_CSP_REPORT_URI_FRONTEND=https://diagnostics.example.com/api/2/security/?glitchtip_key=your_key

# Optional server-side crash reporting. When set, the backend initialises the
# Sentry Python SDK (GlitchTip is Sentry-compatible) and reports unhandled
# exceptions to this DSN. Sent server-to-server, so no CSP change is needed.
# Usually a separate GlitchTip project from the frontend VITE_GLITCHTIP_DSN.
# EASYSHARE_GLITCHTIP_DSN_BACKEND=https://your_key@diagnostics.example.com/3

# Comma-separated reverse-proxy IPs whose X-Forwarded-For uvicorn will trust.
# Read by the Docker entrypoint, so it must be a real environment variable (set
# it in docker-compose, not just this file). Use your proxy's IP in production;
# use "*" only when the backend port is not publicly reachable.
EASYSHARE_FORWARDED_ALLOW_IPS=127.0.0.1

# Logging: level (DEBUG/INFO/WARNING/ERROR) and format ("console" or "json").
# Use "json" in production so logs are machine-parseable by a log shipper.
EASYSHARE_LOG_LEVEL=INFO
EASYSHARE_LOG_FORMAT=console

# Email / restricted-share verification.
# When EASYSHARE_SMTP_HOST is set, unlocking a restricted share requires a
# one-time code emailed to the recipient (proof they control the address).
# Leave it empty to disable verification: restricted shares then accept any
# allow-listed email and the UI warns owners about the weaker guarantee.
# EASYSHARE_SMTP_HOST=smtp.example.com
# EASYSHARE_SMTP_PORT=587
# EASYSHARE_SMTP_USERNAME=apikey
# EASYSHARE_SMTP_PASSWORD=change-me
# EASYSHARE_SMTP_FROM=no-reply@example.com
# EASYSHARE_SMTP_USE_TLS=true
# EASYSHARE_SMTP_TIMEOUT=10
# EASYSHARE_SHARE_VERIFICATION_CODE_TTL_MINUTES=10
# EASYSHARE_SHARE_VERIFICATION_MAX_ATTEMPTS=5
