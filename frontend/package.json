{
  "name": "easyshare-frontend",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "gen:api": "npx -y openapi-typescript@7.13.0 openapi.json -o src/types/api.generated.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucide/vue": "^1.25.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.10.0",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.4.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=22"
  }
}
