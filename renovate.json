{
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "30 days",
  "dependencyDashboard": true,
  "pinDigests": true,
  "hostRules": [
    {
      "matchHost": "data.forgejo.org",
      "hostType": "github"
    }
  ],
  "timezone": "Etc/UTC",
  "labels": [
    "dependencies"
  ],
  "osvVulnerabilityAlerts": true,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on monday"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track data.forgejo.org/actions/git-pages with full semver tag to avoid forgejo-tags major-version reduction bug",
      "managerFilePatterns": ["/^\\.forgejo/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "uses:\\s+https://data\\.forgejo\\.org/actions/git-pages@(?<currentDigest>[a-f0-9]{40})\\s+#\\s+(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "git-pages/action",
      "datasourceTemplate": "forgejo-tags",
      "versioningTemplate": "semver",
      "registryUrlTemplate": "https://codeberg.org"
    },
    {
      "customType": "regex",
      "description": "Track astral-sh/setup-uv via git-refs to work around forgejo-tags API limitation on mirrored actions",
      "managerFilePatterns": ["/^\\.forgejo/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "uses:\\s+https://data\\.forgejo\\.org/astral-sh/setup-uv@(?<currentDigest>[a-f0-9]{40})\\s+#\\s+(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "https://github.com/astral-sh/setup-uv.git",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Track actions/checkout via git-refs to work around forgejo-tags API limitation on mirrored actions",
      "managerFilePatterns": ["/^\\.forgejo/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "uses:\\s+https://data\\.forgejo\\.org/actions/checkout@(?<currentDigest>[a-f0-9]{40})\\s+#\\s+(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "https://github.com/actions/checkout.git",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "semver"
    }
  ],
  "docker-compose": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)(?:compose|docker-compose)[^/]*\\.ya?ml(?:[^/]*\\.example)?$/"
    ]
  },
  "packageRules": [
    {
      "description": "Hold TypeScript on the 6.x line: 7.0 is the native (Go) compiler that vue-tsc, openapi-typescript and typescript-eslint cannot consume yet.",
      "matchPackageNames": ["typescript"],
      "allowedVersions": "<7"
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-major dependency updates"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "dependencies",
        "major-update"
      ]
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["git-pages/action", "astral-sh/setup-uv", "actions/checkout"],
      "enabled": false
    },
    {
      "matchManagers": ["pep621"],
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "matchCategories": [
        "security"
      ],
      "labels": [
        "dependencies",
        "security"
      ],
      "prPriority": 10,
      "groupName": "security updates",
      "dependencyDashboardApproval": false
    },
    {
      "matchUpdateTypes": ["digest", "pinDigest"],
      "minimumReleaseAge": "30 days",
      "matchPackageNames": ["codeberg.org/endurain-project/endurain"],
      "pinDigests": false
    }
  ]
}
